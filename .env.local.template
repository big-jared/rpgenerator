# RPGenerator Server Configuration
# Copy this file to .env.local and fill in your values:
#   cp .env.local.template .env.local
#
# .env.local is gitignored — your keys stay local.

# ── Mode ──────────────────────────────────────────────────────────
# Dev mode: server runs on localhost:8080, no auth required.
# Prod mode: set GOOGLE_OAUTH_CLIENT_ID to enable auth.
#
# To run the dev server:  ./scripts/dev-server.sh
# To deploy to Cloud Run: ./server/deploy.sh

# ── Required ──────────────────────────────────────────────────────
# Google Gemini API key (get one at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# ── Auth (optional — omit for local dev) ──────────────────────────
# Setting this enables auth on all endpoints. Leave blank for local dev.
# GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# ── Server URL (for mobile app) ──────────────────────────────────
# Local dev: use your Mac's WiFi IP so iOS devices on the same network can connect.
# Find your IP: ipconfig getifaddr en0
# Example: SERVER_URL=http://192.168.1.42:8080
#
# Prod: https://rpgenerator-yumkcfwfba-uc.a.run.app
SERVER_URL=http://localhost:8080

# ── LLM Provider (optional) ──────────────────────────────────────
# Options: gemini (default), claude-cli, codex-cli
# You can also set these via ./scripts/dev-server.sh <provider> <model>
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
